{
  "name": "GENEALOGIX Spec",
  "image": "mcr.microsoft.com/devcontainers/go:1.26",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": {
    "go-deps": "go mod download",
    "go-tools": "set -e; tmpfile=$(mktemp); curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/v2.11.4/install.sh -o \"$tmpfile\" && sh \"$tmpfile\" -b $(go env GOPATH)/bin v2.11.4; rm -f \"$tmpfile\"",
    "spec-deps": "cd specification && npm ci",
    "website-deps": "cd website && npm ci"
  },
  "forwardPorts": [5173],
  "customizations": {
    "vscode": {
      "settings": {
        "go.toolsManagement.autoUpdate": true,
        "go.useLanguageServer": true
      },
      "extensions": [
        "golang.Go",
        "esbenp.prettier-vscode",
        "github.vscode-github-actions",
        "anthropic.claude-code",
        "Vue.volar",
        "redhat.vscode-yaml",
        "DavidAnson.vscode-markdownlint"
      ]
    }
  },
  "remoteUser": "vscode"
}
