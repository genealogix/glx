{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/assertion",
  "title": "Assertion",
  "description": "A source-backed claim about an entity. ID comes from the map key in the parent structure.",
  "type": "object",
  "required": ["subject"],
  "allOf": [
    {
      "description": "Must have evidence - either sources or citations",
      "anyOf": [
        { "required": ["sources"] },
        { "required": ["citations"] }
      ]
    },
    {
      "description": "Cannot have both claim and participant",
      "not": {
        "required": ["claim", "participant"]
      }
    },
    {
      "description": "Cannot have both value and participant",
      "not": {
        "required": ["value", "participant"]
      }
    },
    {
      "description": "Must have either claim or participant (but not both)",
      "anyOf": [
        { "required": ["claim"] },
        { "required": ["participant"] }
      ]
    }
  ],
  "properties": {
    "subject": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{1,64}$",
      "description": "The entity this assertion is about"
    },
    "claim": {
      "type": "string",
      "minLength": 1,
      "description": "The property or fact being claimed (required if not using participant)"
    },
    "value": {
      "type": "string",
      "description": "The concluded value of the claim (cannot be used with participant)"
    },
    "participant": {
      "type": "object",
      "description": "Participant in an event or relationship (mutually exclusive with claim/value)",
      "required": ["person"],
      "properties": {
        "person": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-]{1,64}$",
          "description": "Person involved in the participant assertion (required)"
        },
        "role": {
          "type": "string",
          "minLength": 1,
          "description": "Role of the participant"
        },
        "notes": {
          "type": "string",
          "description": "Notes about this participant"
        }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "string",
      "description": "Confidence level in this assertion"
    },
    "notes": {
      "type": "string",
      "description": "General notes about the assertion"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "description": "Direct source references",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9-]{1,64}$"
      },
      "uniqueItems": true
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "description": "Citation references providing evidence",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9-]{1,64}$"
      },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "description": "Tags for categorization",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
