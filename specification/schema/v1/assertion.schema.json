{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/assertion.schema.json",
  "title": "Assertion",
  "description": "A source-backed conclusion about an entity. ID comes from the map key in the parent structure.",
  "type": "object",
  "required": [
    "subject"
  ],
  "allOf": [
    {
      "description": "Must have evidence - at least one of sources, citations, or media",
      "anyOf": [
        {
          "required": [
            "sources"
          ],
          "properties": {
            "sources": {}
          }
        },
        {
          "required": [
            "citations"
          ],
          "properties": {
            "citations": {}
          }
        },
        {
          "required": [
            "media"
          ],
          "properties": {
            "media": {}
          }
        }
      ]
    },
    {
      "description": "Cannot have both property and participant",
      "not": {
        "required": [
          "property",
          "participant"
        ],
        "properties": {
          "property": {},
          "participant": {}
        }
      }
    },
    {
      "description": "Cannot have both value and participant",
      "not": {
        "required": [
          "value",
          "participant"
        ],
        "properties": {
          "value": {},
          "participant": {}
        }
      }
    },
    {
      "description": "value is required when property is present, and vice versa",
      "if": {
        "required": [
          "property"
        ],
        "properties": {
          "property": {}
        }
      },
      "then": {
        "required": [
          "value"
        ],
        "properties": {
          "value": {}
        }
      },
      "else": {
        "not": {
          "required": [
            "value"
          ],
          "properties": {
            "value": {}
          }
        }
      }
    }
  ],
  "properties": {
    "subject": {
      "description": "The entity this assertion is about (typed reference)",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "person": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9-]{1,64}$",
              "description": "Reference to a Person entity"
            }
          },
          "required": [
            "person"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "event": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9-]{1,64}$",
              "description": "Reference to an Event entity"
            }
          },
          "required": [
            "event"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "relationship": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9-]{1,64}$",
              "description": "Reference to a Relationship entity"
            }
          },
          "required": [
            "relationship"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "place": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9-]{1,64}$",
              "description": "Reference to a Place entity"
            }
          },
          "required": [
            "place"
          ],
          "additionalProperties": false
        }
      ]
    },
    "property": {
      "type": "string",
      "minLength": 1,
      "description": "The property being asserted (optional; omit for existential assertions)"
    },
    "value": {
      "type": "string",
      "description": "The concluded value of the property (required when property is present; cannot be used with participant)"
    },
    "date": {
      "type": "string",
      "description": "Date or date range: when property is present, specifies when the value applies; on existential assertions, indicates when the subject existed"
    },
    "participant": {
      "type": "object",
      "description": "Participant in an event or relationship (mutually exclusive with property/value)",
      "required": [
        "person"
      ],
      "properties": {
        "person": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-]{1,64}$",
          "description": "Person involved in the participant assertion (required)"
        },
        "role": {
          "type": "string",
          "minLength": 1,
          "description": "Role of the participant"
        },
        "properties": {
          "type": "object",
          "description": "Per-participant properties",
          "additionalProperties": true
        },
        "notes": {
          "type": "string",
          "description": "Notes about this participant"
        }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "string",
      "description": "Confidence level in this assertion"
    },
    "notes": {
      "type": "string",
      "description": "General notes about the assertion"
    },
    "status": {
      "type": "string",
      "description": "Research status of this assertion (e.g., proven, disproven, speculative)"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "description": "Direct source references",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9-]{1,64}$"
      },
      "uniqueItems": true
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "description": "Citation references providing evidence",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9-]{1,64}$"
      },
      "uniqueItems": true
    },
    "media": {
      "type": "array",
      "minItems": 1,
      "description": "Direct media references providing visual or documentary evidence",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9-]{1,64}$"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
