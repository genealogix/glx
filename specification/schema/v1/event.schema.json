{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/event.schema.json",
  "title": "Event",
  "description": "A genealogical event. ID comes from the map key in the parent structure.",
  "type": "object",
  "required": ["type", "participants"],
  "properties": {
    "type": {
      "type": "string",
      "minLength": 1,
      "description": "Type of event (validated against event_types vocabulary)"
    },
    "properties": {
      "type": "object",
      "description": "Vocabulary-defined properties of the event",
      "additionalProperties": true
    },
    "place": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{1,64}$",
      "description": "Reference to Place where event occurred"
    },
    "date": {
      "type": "string",
      "description": "Date or date range (e.g., '1850-01-15', 'FROM 1870 TO 1890')"
    },
    "participants": {
      "type": "array",
      "description": "People involved in this event",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["person"],
        "properties": {
          "person": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9-]{1,64}$",
            "description": "Reference to Person entity"
          },
          "role": {
            "type": "string",
            "description": "Role of participant in event"
          },
          "notes": {
            "type": "string",
            "description": "Notes about participant's involvement"
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "string",
      "description": "Free-form notes about the event"
    }
  },
  "additionalProperties": false
}




