{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/config/confidence-scales",
  "title": "Confidence Scales Config",
  "type": "object",
  "properties": {
    "scales": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "levels"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
          "label": { "type": "string" },
          "levels": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}


