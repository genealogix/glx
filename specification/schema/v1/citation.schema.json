{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/citation.schema.json",
  "title": "Citation",
  "description": "A specific reference to evidence within a source. ID comes from the map key in the parent structure.",
  "type": "object",
  "required": ["source"],
  "properties": {
    "source": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{1,64}$",
      "description": "Reference to Source entity"
    },
    "repository": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{1,64}$",
      "description": "Reference to Repository where source is held"
    },
    "media": {
      "type": "array",
      "description": "References to Media entities (scans, photos, documents) related to this citation",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9-]{1,64}$"
      },
      "uniqueItems": true
    },
    "properties": {
      "type": "object",
      "description": "Vocabulary-defined properties (locator, text_from_source)",
      "additionalProperties": true
    },
    "notes": {
      "type": "string",
      "description": "Free-form notes about the citation"
    }
  },
  "additionalProperties": false
}




