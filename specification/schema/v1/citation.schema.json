{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema.genealogix.io/v1/citation",
  "title": "Citation",
  "description": "A specific reference to evidence within a source. ID comes from the map key in the parent structure.",
  "type": "object",
  "required": ["source"],
  "properties": {
    "source": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{1,64}$",
      "description": "Reference to Source entity"
    },
    "page": {
      "type": "string",
      "description": "Page number, record number, or location within source"
    },
    "data_date": {
      "type": "string",
      "description": "Date the data was recorded (for documentary sources)"
    },
    "text_from_source": {
      "type": "string",
      "description": "Transcription or excerpt from the source"
    },
    "transcription": {
      "type": "string",
      "description": "Alternative field name for text_from_source"
    },
    "locator": {
      "oneOf": [
        {
          "type": "string",
          "description": "Simple string locator (e.g., 'Page 45, Entry 123')"
        },
        {
          "type": "object",
          "description": "Structured locator information for finding the source",
          "properties": {
            "film_number": {
              "type": "string",
              "description": "FamilySearch film number or microfilm reference"
            },
            "item_number": {
              "type": "string",
              "description": "Item number or accession number"
            },
            "image_number": {
              "type": "string",
              "description": "Image number or page identifier"
            },
            "url": {
              "type": "string",
              "format": "uri",
              "description": "URL to online source"
            },
            "record_id": {
              "type": "string",
              "description": "Database record ID"
            },
            "database_collection": {
              "type": "string",
              "description": "Name of database collection"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "repository": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{1,64}$",
      "description": "Reference to Repository where source is held"
    },
    "media": {
      "type": "array",
      "description": "References to Media entities (scans, photos, documents) related to this citation",
      "items": {
      "type": "string",
        "pattern": "^[a-zA-Z0-9-]{1,64}$"
    },
      "uniqueItems": true
    },
    "notes": {
      "type": "string",
      "description": "Free-form notes about the citation"
    },
    "tags": {
      "type": "array",
      "description": "User-defined tags for organization",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}




