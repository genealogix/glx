{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/archive-metadata",
  "title": "Archive Metadata",
  "description": "Metadata for a GENEALOGIX archive",
  "type": "object",
  "required": ["glx_version"],
  "properties": {
    "glx_version": { 
      "type": "string", 
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "GENEALOGIX specification version" 
    },
    "compatible_with": {
      "type": "array",
      "description": "List of compatible GENEALOGIX versions",
      "items": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
    }
  },
  "additionalProperties": false
}


