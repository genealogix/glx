{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/vocabularies/quality-ratings",
  "title": "Quality Ratings Vocabulary",
  "type": "object",
  "properties": {
    "quality_ratings": {
      "type": "object",
      "patternProperties": {
        "^[0-9]$": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": { "type": "string" },
            "description": { "type": "string" },
            "gedcom": { "type": "string" }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "required": ["quality_ratings"],
  "additionalProperties": false
}

