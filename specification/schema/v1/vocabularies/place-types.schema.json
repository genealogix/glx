{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/vocabularies/place-types.schema.json",
  "title": "Place Types Vocabulary",
  "description": "Defines the standard and custom place types available for place entities",
  "type": "object",
  "required": ["place_types"],
  "properties": {
    "place_types": {
      "type": "object",
      "description": "Map of place type definitions",
      "additionalProperties": {
        "$ref": "#/definitions/PlaceTypeDefinition"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "PlaceTypeDefinition": {
      "type": "object",
      "description": "Definition of a single place type",
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label for the place type"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the place type"
        },
        "category": {
          "type": "string",
          "enum": ["administrative", "geographic", "religious", "institution", "other"],
          "description": "Functional category of the place type"
        }
      }
    }
  }
}
