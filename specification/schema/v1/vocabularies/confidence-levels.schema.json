{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/vocabularies/confidence-levels.schema.json",
  "title": "Confidence Levels Vocabulary",
  "description": "Defines the standard and custom confidence levels available for assertions",
  "type": "object",
  "required": ["confidence_levels"],
  "properties": {
    "confidence_levels": {
      "type": "object",
      "description": "Map of confidence level definitions",
      "additionalProperties": {
        "$ref": "#/definitions/ConfidenceLevelDefinition"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ConfidenceLevelDefinition": {
      "type": "object",
      "description": "Definition of a single confidence level",
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label for the confidence level"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the confidence level"
        }
      }
    }
  }
}
