{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/vocabularies/place-properties.schema.json",
  "title": "Place Properties Vocabulary",
  "description": "Defines the standard and custom properties available for place entities",
  "type": "object",
  "required": [
    "place_properties"
  ],
  "properties": {
    "place_properties": {
      "type": "object",
      "description": "Map of property definitions for places",
      "additionalProperties": {
        "$ref": "#/definitions/PropertyDefinition"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "PropertyDefinition": {
      "type": "object",
      "description": "Definition of a single property",
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label for the property"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the property"
        },
        "value_type": {
          "type": "string",
          "enum": [
            "string",
            "date",
            "integer",
            "boolean"
          ],
          "description": "Data type for non-reference properties"
        },
        "reference_type": {
          "type": "string",
          "enum": [
            "persons",
            "places",
            "events",
            "relationships",
            "sources",
            "citations",
            "repositories",
            "media"
          ],
          "description": "Entity type for reference properties"
        },
        "vocabulary_type": {
          "type": "string",
          "description": "Vocabulary type that constrains allowed values (e.g., gender_types)"
        },
        "temporal": {
          "type": "boolean",
          "description": "Whether this property can vary over time"
        },
        "multi_value": {
          "type": "boolean",
          "description": "Whether this property can have multiple values as an array"
        },
        "gedcom": {
          "type": "string",
          "description": "Corresponding GEDCOM tag for import/export mapping"
        },
        "fields": {
          "type": "object",
          "description": "Sub-schema for structured property components",
          "additionalProperties": {
            "$ref": "#/definitions/FieldDefinition"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "value_type"
          ],
          "properties": {
            "value_type": {}
          }
        },
        {
          "required": [
            "reference_type"
          ],
          "properties": {
            "reference_type": {}
          }
        },
        {
          "required": [
            "vocabulary_type"
          ],
          "properties": {
            "vocabulary_type": {}
          }
        }
      ],
      "allOf": [
        {
          "not": {
            "required": [
              "value_type",
              "reference_type"
            ],
            "properties": {
              "value_type": {},
              "reference_type": {}
            }
          }
        },
        {
          "not": {
            "required": [
              "value_type",
              "vocabulary_type"
            ],
            "properties": {
              "value_type": {},
              "vocabulary_type": {}
            }
          }
        },
        {
          "not": {
            "required": [
              "reference_type",
              "vocabulary_type"
            ],
            "properties": {
              "reference_type": {},
              "vocabulary_type": {}
            }
          }
        }
      ]
    },
    "FieldDefinition": {
      "type": "object",
      "description": "Definition of a field within a structured property",
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label for the field"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the field"
        }
      }
    }
  }
}
