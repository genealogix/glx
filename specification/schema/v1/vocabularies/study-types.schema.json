{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/vocabularies/study-types.schema.json",
  "title": "Study Types Vocabulary",
  "description": "Defines the standard and custom study types available for study entities",
  "type": "object",
  "required": ["study_types"],
  "properties": {
    "study_types": {
      "type": "object",
      "description": "Map of study type definitions",
      "additionalProperties": {
        "$ref": "#/definitions/StudyTypeDefinition"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "StudyTypeDefinition": {
      "type": "object",
      "description": "Definition of a single study type",
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label for the study type"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the study type"
        }
      }
    }
  }
}
