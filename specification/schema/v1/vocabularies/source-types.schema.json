{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/vocabularies/source-types.schema.json",
  "title": "Source Types Vocabulary",
  "description": "Defines the standard and custom source types available for source entities",
  "type": "object",
  "required": ["source_types"],
  "properties": {
    "source_types": {
      "type": "object",
      "description": "Map of source type definitions",
      "additionalProperties": {
        "$ref": "#/definitions/SourceTypeDefinition"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "SourceTypeDefinition": {
      "type": "object",
      "description": "Definition of a single source type",
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label for the source type"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the source type"
        }
      }
    }
  }
}
