{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/vocabularies/source-types",
  "title": "Source Types Vocabulary",
  "type": "object",
  "properties": {
    "source_types": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_-]{1,64}$": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": { "type": "string" },
            "description": { "type": "string" }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "required": ["source_types"],
  "additionalProperties": false
}

