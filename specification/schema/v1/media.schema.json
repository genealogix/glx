{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/media.schema.json",
  "title": "Media",
  "description": "A media object referenced by sources or entities. ID comes from the map key in the parent structure.",
  "type": "object",
  "required": ["uri"],
  "properties": {
    "uri": { "type": "string", "description": "Location of the media file" },
    "type": { "type": "string", "description": "Media type (validated against media_types vocabulary)" },
    "mime_type": { "type": "string", "description": "MIME type of the media" },
    "hash": { "type": "string", "description": "Content hash for verification" },
    "title": { "type": "string", "description": "Title of the media" },
    "description": { "type": "string", "description": "Description of the media" },
    "date": { "type": "string", "description": "Date the media was created" },
    "source": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]{1,64}$",
      "description": "Reference to Source entity this media documents"
    },
    "properties": {
      "type": "object",
      "additionalProperties": true,
      "description": "Vocabulary-defined properties (validated against media_properties vocabulary)"
    },
    "notes": { "type": "string", "description": "Free-form notes" }
  },
  "additionalProperties": false
}
