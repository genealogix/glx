{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/v1/media",
  "title": "Media",
  "description": "A media object referenced by sources or entities. ID comes from the map key in the parent structure.",
  "type": "object",
  "required": ["uri"],
  "properties": {
    "uri": { "type": "string", "minLength": 1 },
    "mime_type": { "type": "string" },
    "hash": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "notes": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  },
  "additionalProperties": false
}


