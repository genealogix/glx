{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/glx/main/specification/schema/meta/schema.schema.json",
  "title": "GENEALOGIX Meta-Schema",
  "description": "Meta-schema used to validate GENEALOGIX JSON Schemas",
  "type": "object",
  "required": ["$schema", "$id", "title", "description", "type"],
  "properties": {
    "$schema": {
      "type": "string",
      "enum": ["http://json-schema.org/draft-07/schema#"]
    },
    "$id": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://raw\\.githubusercontent\\.com/genealogix/glx/main/specification/schema/"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["object"]
    },
    "required": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "properties": {
      "type": "object"
    },
    "definitions": {
      "type": "object"
    },
    "patternProperties": {
      "type": "object"
    },
    "additionalProperties": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "object" }
      ]
    },
    "allOf": {
      "type": "array"
    },
    "anyOf": {
      "type": "array"
    },
    "oneOf": {
      "type": "array"
    },
    "not": {
      "type": "object"
    }
  }
}
