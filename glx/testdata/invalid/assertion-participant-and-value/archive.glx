# Invalid: Both participant and value present
# This should fail validation - they are mutually exclusive

persons:
  person-john:
    version: "1.0"
    properties:
      primary_name: "John Smith"

events:
  event-marriage:
    version: "1.0"
    type: marriage

sources:
  source-cert:
    version: "1.0"
    title: "Certificate"

citations:
  citation-cert:
    version: "1.0"
    source: source-cert

# This is INVALID - cannot have both participant and value
assertions:
  assertion-invalid:
    version: "1.0"
    subject: event-marriage
    participant:
      person: person-john
      role: groom
    value: "some value"  # ERROR: should not be present with participant
    citations:
      - citation-cert
    confidence: high

