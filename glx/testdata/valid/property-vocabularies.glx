# Test file for property vocabularies
# Includes both property vocabularies and minimal test data

# Standard vocabularies
event_types:
  birth:
    label: "Birth"
    description: "Person's birth"

relationship_types:
  marriage:
    label: "Marriage"
    description: "Marriage relationship"

# Property vocabularies demonstrating the new feature
person_properties:
  primary_name:
    label: "Primary Name"
    description: "Person's primary or preferred name"
    value_type: string
    temporal: true
  
  gender:
    label: "Gender"
    description: "Gender identity"
    value_type: string
    temporal: true
  
  born_on:
    label: "Birth Date"
    description: "Date of birth"
    value_type: date
  
  occupation:
    label: "Occupation"
    description: "Profession or trade"
    value_type: string
    temporal: true

event_properties:
  occurred_on:
    label: "Event Date"
    description: "When the event occurred"
    value_type: date
  
  occurred_at:
    label: "Event Location"
    description: "Where the event occurred"
    reference_type: places

relationship_properties:
  started_on:
    label: "Start Date"
    description: "When the relationship began"
    value_type: date
  
  ended_on:
    label: "End Date"
    description: "When the relationship ended"
    value_type: date

place_properties:
  population:
    label: "Population"
    description: "Population count"
    value_type: integer
    temporal: true

# Minimal test data to demonstrate properties in use
persons:
  person-john:
    properties:
      primary_name: "John Smith"
      gender: "male"
      born_on: "1850-01-15"
      occupation:
        - value: "blacksmith"
          date: "1870"
        - value: "farmer"
          date: "FROM 1880 TO 1920"
    notes: "Test person"

  person-jane:
    properties:
      primary_name: "Jane Doe"
      gender: "female"

events:
  event-birth:
    type: birth
    properties:
      occurred_on: "1850-01-15"

relationships:
  rel-marriage:
    type: marriage
    persons:
      - person-john
      - person-jane
    properties:
      started_on: "1880-06-15"

places:
  place-leeds:
    name: "Leeds"
    properties:
      population:
        - value: 50000
          date: "1850"
        - value: 150000
          date: "1900"

