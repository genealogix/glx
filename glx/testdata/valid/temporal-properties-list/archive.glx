# Valid: Temporal property lists with {value, date} structure
# Tests that temporal properties can accept lists of dated values

places:
  place-leeds:
    name: "Leeds"
    type: city

  place-london:
    name: "London"
    type: city

  place-york:
    name: "York"
    type: city

# Vocabularies
place_types:
  city:
    label: "City"
    description: "A city or town"

person_properties:
  name:
    label: "Name"
    description: "Person's name as recorded, with optional structured breakdown"
    value_type: string
    temporal: true
    fields:
      given:
        label: "Given Name"
        description: "Given/first name(s)"
      surname:
        label: "Surname"
        description: "Family name"

  occupation:
    label: "Occupation"
    description: "Profession or trade"
    value_type: string
    temporal: true

  residence:
    label: "Residence"
    description: "Place of residence"
    reference_type: places
    temporal: true

# Person using temporal lists with {value, date} structure
persons:
  person-jane:
    properties:
      # Temporal name property with dated list
      name:
        - value: "Jane Doe"
          date: "FROM 1850 TO 1875"
          fields:
            given: "Jane"
            surname: "Doe"
        - value: "Jane Elizabeth Smith"
          date: "FROM 1875"
          fields:
            given: "Jane Elizabeth"
            surname: "Smith"

      # Temporal value_type with occupation changes
      occupation:
        - value: "seamstress"
          date: "1870"
        - value: "teacher"
          date: "FROM 1880 TO 1900"
        - value: "retired"
          date: "FROM 1900"

      # Temporal reference_type property with dated list
      residence:
        - value: "place-leeds"
          date: "FROM 1850 TO 1880"
        - value: "place-york"
          date: "FROM 1880 TO 1900"
        - value: "place-london"
          date: "FROM 1900"
