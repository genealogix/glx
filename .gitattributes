# Auto-detect text files and normalize line endings
* text=auto

# Go source
*.go text diff=golang

# Documentation
*.md text diff=markdown
*.yaml text diff=yaml
*.yml text diff=yaml
*.json text
*.glx text diff=yaml

# Shell scripts
*.sh text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.tif binary
*.tiff binary
*.pdf binary
*.ged text

# Preserve line endings on GEDCOM test fixtures — disable normalization so the
# files are stored as-is. Test fixtures must be preserved byte-for-byte;
# `* text=auto` would otherwise want to renormalize CRLF fixtures to LF,
# putting git into a "dirty" state on checkout and failing GoReleaser.
glx/testdata/gedcom/**/*.ged -text

# GoReleaser archives
dist/ export-ignore

# Go module files — Go tools always write LF (golang/go#31870)
go.mod text eol=lf
go.sum text eol=lf linguist-generated
