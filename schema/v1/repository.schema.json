{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/spec/main/schema/v1/repository",
  "title": "Repository",
  "description": "An institution or organization that holds genealogical sources",
  "type": "object",
  "required": ["id", "version", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^repository-[a-f0-9]{8}$",
      "description": "Unique identifier for this repository",
      "examples": ["repository-a1b2c3d4"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version",
      "examples": ["1.0"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the repository"
    },
    "type": {
      "type": "string",
      "enum": [
        "archive",
        "library",
        "museum",
        "registry",
        "database",
        "church",
        "historical_society",
        "university",
        "government_agency",
        "other"
      ],
      "description": "Type of repository"
    },
    "address": {
      "type": "string",
      "description": "Street address"
    },
    "city": {
      "type": "string",
      "description": "City or town"
    },
    "state_province": {
      "type": "string",
      "description": "State or province"
    },
    "postal_code": {
      "type": "string",
      "description": "Postal or zip code"
    },
    "country": {
      "type": "string",
      "description": "Country"
    },
    "phone": {
      "type": "string",
      "description": "Telephone number"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "URL to repository website"
    },
    "access_hours": {
      "type": "string",
      "description": "Hours of operation or access"
    },
    "access_restrictions": {
      "type": "string",
      "description": "Any restrictions on access (e.g., by appointment only, membership required)"
    },
    "holding_types": {
      "type": "array",
      "description": "Types of materials held",
      "items": {
        "type": "string",
        "enum": [
          "documents",
          "microfilm",
          "microfiche",
          "digital",
          "books",
          "manuscripts",
          "maps",
          "newspapers",
          "photographs",
          "audio",
          "video",
          "other"
        ]
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this repository record was created"
    },
    "created_by": {
      "type": "string",
      "description": "User who created this record"
    },
    "modified_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this repository record was last modified"
    },
    "modified_by": {
      "type": "string",
      "description": "User who last modified this record"
    },
    "notes": {
      "type": "string",
      "description": "Free-form notes about the repository"
    },
    "tags": {
      "type": "array",
      "description": "User-defined tags for organization",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}




