{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/spec/main/schema/v1/assertion",
  "title": "Assertion",
  "description": "A source-backed claim about an entity",
  "type": "object",
  "required": ["id", "version", "subject", "claim", "sources"],
  "properties": {
    "id": { "type": "string", "pattern": "^assert-[a-f0-9]{8}$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "subject": { "type": "string", "pattern": "^(person|rel)-[a-f0-9]{8}$" },
    "claim": { "type": "string", "minLength": 1 },
    "evidence_type": { "type": "string" },
    "confidence": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^source-[a-f0-9]{8}$" },
      "uniqueItems": true
    },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "modified_at": { "type": "string", "format": "date-time" },
    "modified_by": { "type": "string" }
  },
  "additionalProperties": false
}


