{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema.genealogix.org/v1/archive-metadata",
  "title": "Archive Metadata",
  "description": "Metadata for a GENEALOGIX archive",
  "type": "object",
  "required": ["oracynth_schema_version"],
  "properties": {
    "oracynth_schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "compatible_with": {
      "type": "array",
      "items": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
    }
  },
  "additionalProperties": false
}


