{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/spec/main/schema/v1/source",
  "title": "Source",
  "description": "A source record (document, oral history, media). ID comes from the map key in the parent structure.",
  "type": "object",
  "required": ["version", "title"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "title": { "type": "string", "minLength": 1 },
    "type": { "type": "string" },
    "authors": { "type": "array", "items": { "type": "string" } },
    "date": { "type": "string" },
    "citation": { "type": "string" },
    "description": { "type": "string" },
    "repository": { "type": "string" },
    "repository_id": { "type": "string" },
    "creator": { "type": "string" },
    "publication_info": { "type": "object" },
    "language": { "type": "string" },
    "coverage": { "type": "object" },
    "notes": { "type": "string" },
    "media": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "modified_at": { "type": "string", "format": "date-time" },
    "modified_by": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  },
  "additionalProperties": false
}


