{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/spec/main/schema/v1/vocabularies/place-types",
  "title": "Place Types Vocabulary",
  "type": "object",
  "properties": {
    "place_types": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_-]{1,64}$": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": { "type": "string" },
            "description": { "type": "string" },
            "category": { "type": "string", "enum": ["administrative", "geographic", "religious", "custom"] },
            "custom": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "required": ["place_types"],
  "additionalProperties": false
}

