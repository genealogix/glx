{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/genealogix/spec/main/schema/v1/media",
  "title": "Media",
  "description": "A media object referenced by sources or entities. ID comes from the map key in the parent structure.",
  "type": "object",
  "required": ["version", "uri"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "uri": { "type": "string", "minLength": 1 },
    "mime_type": { "type": "string" },
    "hash": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "modified_at": { "type": "string", "format": "date-time" },
    "modified_by": { "type": "string" }
  },
  "additionalProperties": true
}


