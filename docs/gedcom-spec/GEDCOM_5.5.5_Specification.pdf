							<div class="panel-body">
								<ul class="panel-body-ul-flex">
											<li class="panel-item">
												<div class="panel-item-left">
													<img src="https://docslib.b-cdn.net/cover/8988/heredis-help-heredis-for-windows-2017-release-3-2-creating-a-genealogy-file-12-discover-heredis-9-new-genealogy-file-8988.webp" alt="Heredis Help Heredis for Windows 2017 Release 3.2 Creating a Genealogy File 12 DISCOVER HEREDIS 9 New Genealogy File" width="200">
												</div>
											<div class="panel-item-right">
												<h3 >
													<a href="/doc/8988/heredis-help-heredis-for-windows-2017-release-3-2-creating-a-genealogy-file-12-discover-heredis-9-new-genealogy-file" title="Heredis Help Heredis for Windows 2017 Release 3.2 Creating a Genealogy File 12 DISCOVER HEREDIS 9 New Genealogy File" class="text-overflow-clamp2">
														Heredis Help Heredis for Windows 2017 Release 3.2 Creating a Genealogy File 12 DISCOVER HEREDIS 9 New Genealogy File</a>
												</h3>
