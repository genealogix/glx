# GENEALOGIX Family Archive - Single File Example
# Demonstrates all entity types in one file

# Vocabularies
event_types:
  birth:
    label: "Birth"
    description: "Birth of a person"
    category: lifecycle
  marriage:
    label: "Marriage"
    description: "Marriage ceremony"
    category: lifecycle

relationship_types:
  marriage:
    label: "Marriage"
    description: "Married couple"

place_types:
  country:
    label: "Country"
    description: "Sovereign nation"
  county:
    label: "County"
    description: "County or administrative region"
  city:
    label: "City"
    description: "City or town"

source_types:
  church_register:
    label: "Church Register"
    description: "Parish registers of baptisms, marriages, burials"

repository_types:
  library:
    label: "Library"
    description: "Public or private library"

participant_roles:
  subject:
    label: "Subject"
    description: "Subject of the event"
    applies_to:
      - event
  groom:
    label: "Groom"
    description: "Male marriage participant"
    applies_to:
      - event
  bride:
    label: "Bride"
    description: "Female marriage participant"
    applies_to:
      - event
  spouse:
    label: "Spouse"
    description: "Marriage partner"
    applies_to:
      - relationship

confidence_levels:
  high:
    label: "High Confidence"
    description: "Strong evidence with minimal doubt"

# Property Definitions
person_properties:
  name:
    label: "Name"
    description: "Person's name as recorded, with optional structured breakdown"
    value_type: string
    temporal: true
    fields:
      prefix:
        label: "Prefix"
        description: "Honorific prefix (Dr., Rev., Hon.)"
      given:
        label: "Given Name"
        description: "Given/first name(s)"
      nickname:
        label: "Nickname"
        description: "Familiar or descriptive name"
      surname_prefix:
        label: "Surname Prefix"
        description: "Article or prefix (von, van, de)"
      surname:
        label: "Surname"
        description: "Family name"
      suffix:
        label: "Suffix"
        description: "Generational suffix (Jr., Sr., III)"

  born_on:
    label: "Birth Date"
    description: "Date of birth"
    value_type: date
  
  died_on:
    label: "Death Date"
    description: "Date of death"
    value_type: date
  
  gender:
    label: "Gender"
    description: "Gender identity"
    value_type: string

citation_properties:
  locator:
    label: "Locator"
    description: "Location within source where cited material can be found"
    value_type: string
  text_from_source:
    label: "Text from Source"
    description: "Transcription or excerpt of relevant text from the source"
    value_type: string

persons:
  person-a1b2c3d4:
    properties:
      name:
        value: "John Smith"
        fields:
          given: "John"
          surname: "Smith"
      born_on: "1850-01-15"
      died_on: "1920-06-20"
      gender: "male"

  person-b2c3d4e5:
    properties:
      name:
        value: "Mary Brown"
        fields:
          given: "Mary"
          surname: "Brown"
      born_on: "1852-03-20"
      gender: "female"

relationships:
  rel-12345678:
    type: marriage
    participants:
      - person: person-a1b2c3d4
        role: spouse
      - person: person-b2c3d4e5
        role: spouse
    start_event: event-23456789

events:
  event-a1a2a3a4:
    type: birth
    date: "1850-01-15"
    place: place-c3d4e5f6
    participants:
      - person: person-a1b2c3d4
        role: subject
  
  event-23456789:
    type: marriage
    date: "1875-05-10"
    place: place-c3d4e5f6
    participants:
      - person: person-a1b2c3d4
        role: groom
      - person: person-b2c3d4e5
        role: bride

places:
  place-a1a1a1a1:
    name: "England"
    type: country
  
  place-b2b2b2b2:
    name: "Yorkshire"
    type: county
    parent: place-a1a1a1a1
  
  place-c3d4e5f6:
    name: "Leeds"
    type: city
    parent: place-b2b2b2b2

sources:
  source-12345678:
    title: "St. Paul's Parish Register"
    type: church_register
    repository: repository-a1b2c3d4

citations:
  citation-abcdef12:
    source: source-12345678
    properties:
      locator: "Entry 145, Page 23"
      text_from_source: "John Smith, born January 15, 1850"

repositories:
  repository-a1b2c3d4:
    name: "Leeds Library Local Studies"
    type: library
    website: "https://www.leeds.gov.uk/libraries"

assertions:
  assertion-1a2b3c4d:
    subject:
      person: person-a1b2c3d4
    property: born_on
    value: "1850-01-15"
    citations:
      - citation-abcdef12
    confidence: high
